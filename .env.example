# Copy this file to .env.local and fill in the values.
# Both end up in the client bundle at build time — not server-side secrets.

# Booking-form Google Apps Script Web App URL.
VITE_FORM_ENDPOINT=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Shared token the form sends; must match FORM_TOKEN in the Apps Script.
VITE_FORM_TOKEN=change-me

# Canonical site URL — used for OG tags, JSON-LD, and canonical links.
# Set this to your final production domain (no trailing slash).
VITE_SITE_URL=https://ganeshpartheeban.in
