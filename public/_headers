# Hashed build assets — safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts shipped from node_modules build
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Image variants — content-addressable filenames
/gallery-thumbs/*
  Cache-Control: public, max-age=31536000, immutable

/hero-*
  Cache-Control: public, max-age=31536000, immutable

# Stable site assets
/favicon.svg
  Cache-Control: public, max-age=31536000, immutable
/apple-touch-icon.png
  Cache-Control: public, max-age=31536000, immutable
/og-hero.jpg
  Cache-Control: public, max-age=31536000, immutable
